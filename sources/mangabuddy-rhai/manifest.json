{
  "manifest_version": 1,
  "id": "mangabuddy",
  "name": "MangaBuddy",
  "version": "1.0.0",
  "description": "MangaBuddy - Popular manga, manhwa, and manhua aggregator",
  "author": {"name": "Tsubaki Team", "url": "https://github.com/tsubaki"},
  "license": "MIT",
  "repository": "https://github.com/ghero101/Tsubaki_Extensions",
  "addon_type": "scraper",
  "icon_path": "icon.png",
  "nsfw": false,
  "technology": "rhai",
  "entry_point": {"file": "plugin.rhai"},
  "capabilities": {
    "level": "http_only",
    "allowed_domains": ["mangabuddy.com"],
    "requires_cookies": false,
    "requires_javascript": false,
    "cloudflare_protected": false
  },
  "features": {
    "search": true,
    "browse": true,
    "get_series": true,
    "get_chapters": true,
    "get_pages": true,
    "download": true,
    "get_covers": true
  },
  "authentication": {"type": "none"},
  "source_info": {
    "base_url": "https://mangabuddy.com",
    "language": "en",
    "supported_languages": ["en"],
    "content_rating": "suggestive",
    "tags": ["manga", "manhwa", "manhua", "aggregator"]
  },
  "rate_limiting": {
    "requests_per_minute": 30,
    "burst_limit": 3
  },
  "update": {
    "url": "https://raw.githubusercontent.com/ghero101/Tsubaki_Extensions/master/sources/mangabuddy-rhai/manifest.json",
    "auto_update": true,
    "download_url": "https://raw.githubusercontent.com/ghero101/Tsubaki_Extensions/master/dist/mangabuddy-rhai/mangabuddy-rhai_latest.zip"
  }
}
