{
  "manifest_version": 1,
  "id": "toonily",
  "name": "Toonily",
  "version": "1.0.0",
  "description": "Toonily - Korean manhwa and webtoon reader",
  "author": {
    "name": "Tsubaki Team",
    "url": "https://github.com/tsubaki"
  },
  "license": "MIT",
  "repository": "https://github.com/ghero101/Tsubaki_Extensions",
  "addon_type": "scraper",
  "icon_path": "icon.png",
  "nsfw": true,
  "technology": "rhai",
  "entry_point": {
    "file": "plugin.rhai"
  },
  "capabilities": {
    "level": "http_only",
    "allowed_domains": [
      "toonily.com"
    ],
    "requires_cookies": false,
    "requires_javascript": false,
    "cloudflare_protected": true
  },
  "features": {
    "search": true,
    "browse": true,
    "get_series": true,
    "get_chapters": true,
    "get_pages": true,
    "download": true,
    "get_covers": true
  },
  "authentication": {
    "type": "none"
  },
  "source_info": {
    "base_url": "https://toonily.com",
    "language": "en",
    "supported_languages": [
      "en"
    ],
    "content_rating": "nsfw",
    "tags": [
      "manhwa",
      "webtoon",
      "adult"
    ]
  },
  "rate_limiting": {
    "requests_per_minute": 30,
    "burst_limit": 3
  },
  "update": {
    "url": "https://raw.githubusercontent.com/ghero101/Tsubaki_Extensions/master/sources/toonily-rhai/manifest.json",
    "auto_update": true,
    "download_url": "https://raw.githubusercontent.com/ghero101/Tsubaki_Extensions/master/dist/toonily-rhai/toonily-rhai_latest.zip"
  }
}
